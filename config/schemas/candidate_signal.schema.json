{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "config/schemas/candidate_signal.schema.json",
  "title": "Opportunity Discovery Candidate Signal",
  "description": "Schema for candidate signals in AI Company OS Opportunity Discovery Loop",
  "type": "object",
  "required": [
    "candidate_id",
    "candidate_type",
    "title",
    "created_at",
    "signal_source",
    "primary_engine",
    "related_product_lines",
    "evidence_gate_status",
    "recommended_route",
    "status"
  ],
  "properties": {
    "candidate_id": {
      "type": "string",
      "pattern": "^CD-\\d{8}-\\d{3}$"
    },
    "candidate_type": {
      "type": "string",
      "enum": ["venture_opportunity", "os_improvement"]
    },
    "title": {
      "type": "string",
      "maxLength": 120
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "signal_source": {
      "type": "object",
      "required": ["source_type", "source_tier"],
      "properties": {
        "source_type": {
          "type": "string",
          "enum": [
            "user_complaint", "ai_capability", "market_trend",
            "platform_shift", "asset_scan", "os_feedback"
          ]
        },
        "source_tier": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3
        },
        "source_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": { "type": "string" },
              "excerpt": { "type": "string" },
              "type": { "type": "string" },
              "detail": { "type": "string" }
            }
          }
        }
      }
    },
    "signal_type": {
      "type": "string",
      "enum": ["pain", "capability", "trend", "platform", "asset", "system_gap"]
    },
    "primary_engine": {
      "type": "string",
      "enum": [
        "cash_engine", "attention_engine", "platform_play",
        "content_engine", "knowledge_asset", "os_evolution"
      ]
    },
    "secondary_engines": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_product_lines": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "string",
        "enum": [
          "ai_company_os", "ai_seller_finance", "ai_content_products",
          "ai_game_products", "ai_short_drama", "knowledge_assets",
          "saas_microtools", "platform_ecosystem_experiments"
        ]
      }
    },
    "company_context_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "target_user": { "type": "string" },
    "pain": { "type": "string" },
    "evidence_summary": { "type": "string" },
    "why_now": { "type": "string" },
    "founder_fit_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "asset_leverage_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "mvp_wedge": { "type": "string" },
    "distribution_hint": { "type": "string" },
    "risk": { "type": "string" },
    "missing_evidence": { "type": "string" },
    "evidence_gate_status": {
      "type": "string",
      "enum": ["passed", "needs_more_evidence", "weak_candidate"]
    },
    "recommended_route": {
      "type": "string",
      "enum": [
        "promote_signal", "request_card", "request_deep_research",
        "park", "dismiss", "create_os_improvement_task"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["candidate", "promoted", "dismissed", "needs_more_evidence"]
    }
  }
}
