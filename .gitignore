# @PLATFORM Git ignore rules
# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# Node
node_modules/
.next/

# IDE
.vscode/
.idea/

# Environment
.env
.env.local
.env.*.local

# Database — local dev artifacts, not for public repo
*.db
*.sqlite
*.sqlite3

# OS
.DS_Store
Thumbs.db

# Logs
*.log
backend/data/*.log

# Next.js
frontend/next-env.d.ts

# Staging — Code-Capable Runtime 暂存目录
.ai-company-os/
backend/.ai-company-os/
