{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Execution Record Schema",
  "required": ["record_id", "task_id", "project_id", "completed_at"],
  "properties": {
    "record_id": {"type": "string"},
    "task_id": {"type": "string"},
    "project_id": {"type": "string"},
    "agent_chain": {"type": "array", "items": {"type": "string"}},
    "timeout_count": {"type": "integer"},
    "fallback_history": {"type": "array", "items": {"type": "string"}},
    "degradation_flag": {"type": "boolean"},
    "final_output_path": {"type": "string"},
    "result": {"type": "string", "enum": ["PASS", "REVISION_REQUIRED", "BLOCKED"]},
    "completed_at": {"type": "string"}
  }
}
