{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["plan_summary", "risk", "impact", "files", "diff"],
  "additionalProperties": false,
  "properties": {
    "plan_summary": { "type": "string", "description": "1-3 sentences describing what to change and how" },
    "risk": { "type": "string", "enum": ["low", "medium", "high"] },
    "impact": { "type": "string", "description": "Which components/services are affected" },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "change"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string", "description": "File path relative to repo root" },
          "change": { "type": "string", "description": "What to add/remove/modify in this file" }
        }
      },
      "minItems": 1
    },
    "diff": { "type": "string", "description": "Complete git diff in unified format showing all changes" }
  }
}
